<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shanhe.project.device.config.mapper.BatteryReportLogMapper">

    <resultMap id="BaseResultMap" type="com.shanhe.project.device.config.domain.BatteryReportLog">
        <id property="id" column="id" />
        <result property="configId" column="config_id" />
        <result property="packNum" column="pack_num" />
        <result property="packData" column="pack_data" />
        <result property="monitorData" column="monitor_data" />
        <result property="extendData" column="extend_data" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <sql id="Base_Column_List">
        id,config_id,pack_num,pack_data,monitor_data,extend_data,create_time
    </sql>

    <insert id="insert">
        insert into dev_battery_report_log
        (config_id,pack_num,pack_data,monitor_data,extend_data,create_time)
        values
            (#{configId},#{packNum},#{packData},#{monitorData},#{extendData},datetime(CURRENT_TIMESTAMP,'localtime'))
    </insert>

    <insert id="insertList">
        insert into dev_battery_report_log
        (config_id,pack_num,pack_data,monitor_data,extend_data,create_time)
        values
        <foreach collection="list" item="item" separator=",">
            (#{item.configId},#{item.packNum},#{item.packData},#{item.monitorData},#{item.extendData},datetime(CURRENT_TIMESTAMP,'localtime'))
        </foreach>
    </insert>

    <select id="selectLast" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from dev_battery_report_log
        where pack_num = #{packNum}
        order by id desc
        limit 1
    </select>

    <select id="selectBatteryReportLog" parameterType="com.shanhe.project.device.config.domain.BatteryReportLog" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List"/>
        from dev_battery_report_log
        <where>
            <if test="configId != null "> and config_id = #{configId}</if>
            <if test="packNum != null "> and pack_num = #{packNum}</if>
            <if test="params.beginTime != null and params.beginTime != ''"><!-- 开始时间检索 -->
                and strftime('%Y-%m-%d %H:%M:%S', create_time) &gt;= strftime('%Y-%m-%d %H:%M:%S', #{params.beginTime})
            </if>
            <if test="params.endTime != null and params.endTime != ''"><!-- 结束时间检索 -->
                and strftime('%Y-%m-%d %H:%M:%S', create_time) &lt;= strftime('%Y-%m-%d %H:%M:%S', #{params.endTime})
            </if>
        </where>
        order by id desc
    </select>

    <delete id="deleteByIds">
        delete from dev_battery_report_log where id in
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteByDays" parameterType="Integer">
        delete from dev_battery_report_log where create_time &lt;= DATE('now', '-${dayNum} day', 'localtime')
    </delete>

    <delete id="deleteByConfigId">
        delete from dev_battery_report_log where config_id = #{configId}
        <if test="packNum != null ">
            and pack_num = #{packNum}
        </if>
    </delete>

    <select id="selectCount" resultType="java.lang.Long">
        select
        count()
        from dev_battery_report_log
        <where>
            <if test="configId != null ">
                and config_id = #{configId}
            </if>
            <if test="packNum != null ">
                and pack_num = #{packNum}
            </if>
            <if test="params.beginTime != null and params.beginTime != ''">
                <!-- 开始时间检索 -->
                and strftime('%Y-%m-%d %H:%M:%S', create_time) &gt;= strftime('%Y-%m-%d %H:%M:%S', #{params.beginTime})
            </if>
            <if test="params.endTime != null and params.endTime != ''">
                <!-- 结束时间检索 -->
                and strftime('%Y-%m-%d %H:%M:%S', create_time) &lt;= strftime('%Y-%m-%d %H:%M:%S', #{params.endTime})
            </if>
        </where>
    </select>
</mapper>
