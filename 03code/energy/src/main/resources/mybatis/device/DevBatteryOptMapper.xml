<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shanhe.project.device.config.mapper.DevBatteryOptMapper">

    <sql id="selectDevBatteryOptVo">
        opt_id as optId ,
        pack_num as packNum ,
        config_id as configId ,
        test_type as testType ,
        is_enabled as isEnabled ,
        test_time as testTime ,
        end_voltage as endVoltage ,
        rec_voltage as recVoltage ,
        Interval_days as intervalDays ,
        exec_count as execCount ,
        discharge_time as dischargeTime ,
        opt_command as optCommand ,
        create_time as createTime ,
        update_time as updateTime
    </sql>

    <select id="selectDevBatteryOptList" parameterType="com.shanhe.project.device.config.domain.DevBatteryOpt"
            resultType="com.shanhe.project.device.config.domain.DevBatteryOpt">
        select
        <include refid="selectDevBatteryOptVo"/>
        from dev_battery_opt
        <where>
            <if test="packNum != null ">
                and pack_num = #{packNum}
            </if>
            <if test="configId != null ">
                and config_id = #{configId}
            </if>
            <if test="testType != null ">
                and test_type = #{testType}
            </if>
            <if test="isEnabled != null ">
                and is_enabled = #{isEnabled}
            </if>
            <if test="testTime != null ">
                and test_time = #{testTimeStr}
            </if>
            <if test="endVoltage != null ">
                and end_voltage = #{endVoltage}
            </if>
            <if test="recVoltage != null ">
                and rec_voltage = #{recVoltage}
            </if>
            <if test="intervalDays != null ">
                and Interval_days = #{intervalDays}
            </if>
            <if test="execCount != null ">
                and exec_count = #{execCount}
            </if>
            <if test="dischargeTime != null ">
                and discharge_time = #{dischargeTime}
            </if>
            <if test="optCommand != null  and optCommand != ''">
                and opt_command = #{optCommand}
            </if>
        </where>
    </select>

    <select id="selectDevBatteryOptByOptId" parameterType="Long"
        resultType="com.shanhe.project.device.config.domain.DevBatteryOpt">
        select
        <include refid="selectDevBatteryOptVo"/>
        from dev_battery_opt
        where opt_id = #{optId}
    </select>

    <insert id="insertDevBatteryOpt" parameterType="com.shanhe.project.device.config.domain.DevBatteryOpt">
        insert into dev_battery_opt
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="optId != null">
                opt_id,
            </if>
            <if test="packNum != null">
                pack_num,
            </if>
            <if test="configId != null">
                config_id,
            </if>
            <if test="testType != null">
                test_type,
            </if>
            <if test="isEnabled != null">
                is_enabled,
            </if>
            <if test="testTime != null">
                test_time,
            </if>
            <if test="endVoltage != null">
                end_voltage,
            </if>
            <if test="recVoltage != null">
                rec_voltage,
            </if>
            <if test="intervalDays != null">
                Interval_days,
            </if>
            <if test="execCount != null">
                exec_count,
            </if>
            <if test="dischargeTime != null">
                discharge_time,
            </if>
            <if test="optCommand != null">
                opt_command,
            </if>
                create_time,
                update_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="optId != null">
                #{optId},
            </if>
            <if test="packNum != null">
                #{packNum},
            </if>
            <if test="configId != null">
                #{configId},
            </if>
            <if test="testType != null">
                #{testType},
            </if>
            <if test="isEnabled != null">
                #{isEnabled},
            </if>
            <if test="testTime != null">
                #{testTimeStr},
            </if>
            <if test="endVoltage != null">
                #{endVoltage},
            </if>
            <if test="recVoltage != null">
                #{recVoltage},
            </if>
            <if test="intervalDays != null">
                #{intervalDays},
            </if>
            <if test="execCount != null">
                #{execCount},
            </if>
            <if test="dischargeTime != null">
                #{dischargeTime},
            </if>
            <if test="optCommand != null">
                #{optCommand},
            </if>
            datetime(CURRENT_TIMESTAMP,'localtime'),
            datetime(CURRENT_TIMESTAMP,'localtime'),
        </trim>
    </insert>

    <insert id="insertDevBatteryOptList" >
        insert into dev_battery_opt (
            opt_id ,
            pack_num ,
            config_id ,
            test_type ,
            is_enabled ,
            test_time ,
            end_voltage ,
            rec_voltage ,
            Interval_days ,
            exec_count ,
            discharge_time ,
            opt_command ,
            create_time ,
            update_time
        ) values
        <foreach collection="list" item="item" separator=",">
            (
                #{item.optId} ,
                #{item.packNum} ,
                #{item.configId} ,
                #{item.testType} ,
                #{item.isEnabled} ,
                #{item.testTimeStr} ,
                #{item.endVoltage} ,
                #{item.recVoltage} ,
                #{item.intervalDays} ,
                #{item.execCount} ,
                #{item.dischargeTime} ,
                #{item.optCommand} ,
                datetime(CURRENT_TIMESTAMP,'localtime'),
                datetime(CURRENT_TIMESTAMP,'localtime')
            )
        </foreach>

    </insert>

    <update id="updateDevBatteryOpt" parameterType="com.shanhe.project.device.config.domain.DevBatteryOpt">
        update dev_battery_opt
        <trim prefix="SET" suffixOverrides=",">
            <if test="packNum != null">
                pack_num = #{packNum},
            </if>
            <if test="configId != null">
                config_id = #{configId},
            </if>
            <if test="testType != null">
                test_type = #{testType},
            </if>
            <if test="isEnabled != null">
                is_enabled = #{isEnabled},
            </if>
            <if test="testTime != null">
                test_time = #{testTimeStr},
            </if>
            <if test="endVoltage != null">
                end_voltage = #{endVoltage},
            </if>
            <if test="recVoltage != null">
                rec_voltage = #{recVoltage},
            </if>
            <if test="intervalDays != null">
                Interval_days = #{intervalDays},
            </if>
            <if test="execCount != null">
                exec_count = #{execCount},
            </if>
            <if test="dischargeTime != null">
                discharge_time = #{dischargeTime},
            </if>
            <if test="optCommand != null">
                opt_command = #{optCommand},
            </if>
            update_time = datetime(CURRENT_TIMESTAMP,'localtime'),
        </trim>
        where opt_id = #{optId}
    </update>

    <delete id="deleteDevBatteryOptByOptId" parameterType="Long">
        delete from dev_battery_opt where opt_id = #{optId}
    </delete>

    <delete id="deleteDevBatteryOptByOptIds" parameterType="String">
        delete from dev_battery_opt where opt_id in
        <foreach item="optId" collection="optIds" open="(" separator="," close=")">
            #{optId}
        </foreach>
    </delete>

    <delete id="deleteByConfigId">
        delete from dev_battery_opt where config_id = #{configId}
        <if test="packNum != null">
            and pack_num = #{packNum}
        </if>
    </delete>
</mapper>