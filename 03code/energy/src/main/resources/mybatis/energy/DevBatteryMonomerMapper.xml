<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shanhe.project.energy.stat.mapper.DevBatteryMonomerMapper">

    <resultMap type="com.shanhe.project.energy.stat.domain.DevBatteryMonomer" id="DevBatteryMonomerResult">
        <result property="id" column="id"/>
        <result property="packId" column="pack_id"/>
        <result property="batNum" column="bat_num"/>
        <result property="resistance" column="resistance"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <sql id="selectDevBatteryMonomerVo">
        id as id,
        pack_id as packId ,
                bat_num as batNum ,
                resistance as resistance ,
                create_time as createTime
    </sql>

    <select id="selectList" parameterType="com.shanhe.project.energy.stat.domain.DevBatteryMonomer"
            resultType="com.shanhe.project.energy.stat.domain.DevBatteryMonomer">
        select
        <include refid="selectDevBatteryMonomerVo"/>
        from dev_battery_monomer
        where pack_id = #{packId}
    </select>

    <insert id="insertList" >
        insert into dev_battery_monomer (
        pack_id ,
        bat_num ,
        resistance ,
        create_time
        ) values
        <foreach collection="list" item="item" separator=",">
            (
            #{item.packId} ,
            #{item.batNum} ,
            #{item.resistance} ,
            datetime(CURRENT_TIMESTAMP,'localtime')
            )
        </foreach>
    </insert>

    <delete id="deleteByPackId">
        delete from dev_battery_monomer where pack_id = #{packId}
    </delete>

    <delete id="delete">
        delete from dev_battery_monomer
    </delete>
</mapper>