<?xml version="1.0" encoding="UTF-8"?>
<ehcache name="shanhe" updateCheck="false">

    <!-- CacheManager级别全局设置 -->
    <!-- maxBytesLocalHeap:限制缓存所能使用的堆内存的最大字节数的 -->
    <!-- maxBytesLocalOffHeap:限制缓存所能使用的非堆内存的最大字节数 -->
    <!-- maxBytesLocalDisk:限制缓存所能使用的磁盘的最大字节数的 -->

    <!-- 磁盘缓存位置 -->
    <diskStore path="java.io.tmpdir"/>
    
    <!-- maxEntriesLocalHeap:堆内存中最大缓存对象数，0没有限制 -->
    <!-- maxElementsInMemory： 在内存中缓存的element的最大数目。-->
    <!-- eternal:elements是否永久有效，如果为true，timeouts将被忽略，element将永不过期 -->
    <!-- timeToIdleSeconds:失效前的空闲秒数，当eternal为false时，这个属性才有效，0为不限制 -->
    <!-- timeToLiveSeconds:失效前的存活秒数，创建时间到失效时间的间隔为存活时间，当eternal为false时，这个属性才有效，0为不限制 -->
    <!-- overflowToDisk： 如果内存中数据超过内存限制，是否要缓存到磁盘上 -->
    <!-- statistics：是否收集统计信息。如果需要监控缓存使用情况，应该打开这个选项。默认为关闭（统计会影响性能）。设置statistics="true"开启统计 -->
    <!-- memoryStoreEvictionPolicy：指当内存中的数据超过内存限制时，系统会根据指定的策略去清理内存的策略。LRU（最近最少使用）FIFO（先进先出）LFU（较少使用） -->

    <!-- 默认缓存 -->
    <defaultCache
            maxEntriesLocalHeap="200"
            eternal="false"
            timeToIdleSeconds="36000"
            timeToLiveSeconds="36000"
            overflowToDisk="true"
            memoryStoreEvictionPolicy="LRU"
            statistics="false">
    </defaultCache>

    <!-- 系统用户授权缓存  没必要过期 -->
    <cache name="sys-authCache"
           maxEntriesLocalHeap="100"
           overflowToDisk="true"
           eternal="false"
           timeToIdleSeconds="3600"
           timeToLiveSeconds="10800"
           memoryStoreEvictionPolicy="LRU"
           statistics="false"/>

    <!-- 系统缓存 -->
    <cache name="sys-cache"
           maxEntriesLocalHeap="100"
           eternal="true"
           overflowToDisk="true"
           memoryStoreEvictionPolicy="LRU"
           statistics="false">
    </cache>

    <!-- 设备配置缓存 -->
    <cache name="device-config"
           maxEntriesLocalHeap="100"
           eternal="true"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备属性缓存 -->
    <cache name="device-attribute"
           maxEntriesLocalHeap="1000"
           eternal="true"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备协议缓存 -->
    <cache name="device-protocol"
           maxEntriesLocalHeap="100"
           eternal="true"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备协议缓存 -->
    <cache name="device-log"
           maxEntriesLocalHeap="100"
           eternal="true"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备告警缓存 -->
    <cache name="device-alarm"
           maxEntriesLocalHeap="500"
           eternal="true"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 数据存储间隔缓存 -->
    <cache name="data-storage-time"
           maxEntriesLocalHeap="1000"
           eternal="false"
           timeToLiveSeconds="172800"
           overflowToDisk="true"
           memoryStoreEvictionPolicy="LRU"
           statistics="false">
    </cache>

    <!-- 单体电池历史缓存 -->
    <cache name="device-battery-report"
           maxEntriesLocalHeap="100"
           eternal="false"
           timeToIdleSeconds="3600"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 单体电池历史缓存 -->
    <cache name="device-battery"
           maxEntriesLocalHeap="100"
           eternal="false"
           timeToIdleSeconds="3600"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 单体电池历史缓存 -->
    <cache name="stat-battery"
           maxEntriesLocalHeap="20"
           eternal="false"
           timeToIdleSeconds="3600"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备执行结果 -->
    <cache name="device-result"
           maxEntriesLocalHeap="50"
           eternal="false"
           timeToIdleSeconds="20"
           timeToLiveSeconds="20"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备上报协议缓存 -->
    <cache name="comm-data"
           maxEntriesLocalHeap="10"
           eternal="false"
           timeToIdleSeconds="10"
           timeToLiveSeconds="10"
           overflowToDisk="true"
           statistics="false">
    </cache>

    <!-- 设备上报协议缓存 -->
    <cache name="device-warn"
           maxEntriesLocalHeap="10"
           eternal="false"
           timeToIdleSeconds="120"
           timeToLiveSeconds="120"
           overflowToDisk="true"
           statistics="false">
    </cache>
</ehcache>
